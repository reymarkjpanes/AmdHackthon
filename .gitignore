/node_modules
frontend/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# Python virtualenvs
backend/venv*/
venv/
.venv/

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
frontend/dist/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env
