# LLM Provider — choose one: GROQ, CLAUDE, or AMD
LLM_PROVIDER=GROQ

# Groq API (https://console.groq.com — free tier available)
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic Claude (optional fallback)
ANTHROPIC_API_KEY=your_claude_key_here

# AMD Developer Cloud (optional — future AMD MI300X integration)
AMD_CLOUD_API_KEY=your_amd_key_here
AMD_CLOUD_ENDPOINT=https://api.amd-developer-cloud.com/v1

# CORS — comma-separated origins (default: all)
ALLOWED_ORIGINS=http://localhost:3000

# Server port
PORT=8000

# Persistence directories (optional — defaults to backend/data/)
# SESSION_PERSIST_DIR=/path/to/sessions
# CHROMA_PERSIST_DIR=/path/to/chroma
